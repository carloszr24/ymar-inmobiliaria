# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Misma pantalla → service_role (solo servidor; nunca en el cliente ni NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Panel /admin: contraseña + PIN (los dos son obligatorios para entrar)
ADMIN_PASSWORD="cambia-esto"
ADMIN_PIN="000000"
# Secreto largo y aleatorio para firmar sesiones (openssl rand -base64 32). Obligatorio en producción.
ADMIN_SESSION_SECRET=""
# Opcional: solo estas IPs pueden acceder a /admin (separadas por coma). Vacío = cualquier IP.
# ADMIN_ALLOWED_IPS="203.0.113.10,198.51.100.22"
# Duración de sesión en horas (por defecto 12; máximo 168)
# ADMIN_SESSION_MAX_AGE_HOURS="12"

# Email público de contacto (visible en la web)
NEXT_PUBLIC_CONTACT_EMAIL="ymarinmobiliaria@gmail.com"

# URL pública del sitio (opcional; usada en páginas legales)
NEXT_PUBLIC_SITE_URL="https://ymar-inmobiliaria.vercel.app"

# Los correos de nuevos leads se envían desde Supabase (Edge Function notify-lead).
# Configura RESEND_API_KEY y demás en: Supabase → Edge Functions → Secrets
# No hace falta añadir variables de email en Vercel.
